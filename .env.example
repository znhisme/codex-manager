# OpenAI 自动注册系统 - 环境变量配置示例
# 复制此文件为 .env 并填写对应值

# ── Web UI 监听地址 ──────────────────────────────────────────
# 监听主机（默认 0.0.0.0）
# APP_HOST=0.0.0.0

# 监听端口（默认 8000）
# APP_PORT=8000

# Web UI 访问密钥（默认 admin123，强烈建议修改）
# APP_ACCESS_PASSWORD=your_secret_password

# ── 数据库 ───────────────────────────────────────────────────
# 本地 SQLite（默认，无需配置）
# APP_DATABASE_URL=data/database.db

# 远程 PostgreSQL（优先）
# APP_DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Playwright 浏览器节流（可选） ────────────────────────────
# 建议保守值（降低 add-phone/风控概率）
# BROWSER_DELAY_MULTIPLIER=1.5
# BROWSER_TIMEOUT_MULTIPLIER=1.35
# BROWSER_OAUTH_PRE_DELAY_SECONDS=12
# BROWSER_OAUTH_PRE_DELAY_JITTER_SECONDS=6
# BROWSER_OAUTH_HTTP_FIRST=0
# BROWSER_OAUTH_HTTP_ONLY=0
# ── HTTP OAuth / CloudMail 日志降噪（默认推荐） ────────────────
# HTTP OAuth 默认安静模式：抑制 Cookie 诊断、逐跳重定向等高频噪音
# HTTP_OAUTH_QUIET=1
# 如需完整排障链路，临时打开详细追踪（会覆盖 quiet）
# HTTP_OAUTH_VERBOSE_TRACE=0
# 如需打印每次请求重试异常细节
# HTTP_REQUEST_RETRY_VERBOSE=0
# CloudMail 轮询噪音静默（保留成功/超时关键日志）
# CLOUD_MAIL_QUIET=1
# CloudMail 返回内容片段调试（仅排障临时开启）
# CLOUD_MAIL_VERBOSE_CONTENT=0
